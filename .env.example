# ==========================================
# ENVIRONMENT CONFIGURATION EXAMPLE
# ==========================================
# Copy this file to .env and update the values for your environment
# NEVER commit .env file to version control!

# ==========================================
# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=sokapptest
DB_CONNECTION_LIMIT=10
DB_SSL=true

# ==========================================
# Server Configuration
# ==========================================
# Backend API server port
PORT=5000
# Environment: development, production, test
NODE_ENV=development

# ==========================================
# Session Configuration
# ==========================================
# Change this to a strong random string in production
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
SESSION_TIMEOUT=3600000

# ==========================================
# Email Configuration (Brevo)
# ==========================================
BREVO_API_KEY=xkeysib-your-actual-brevo-api-key-here
EMAIL_FROM=no_reply@sokapp.online
BREVO_SENDER_EMAIL=no_reply@sokapp.online
# ==========================================
# API URLs - CRITICAL FOR DEPLOYMENT
# ==========================================
# IMPORTANT: In production, ALL these URLs MUST be updated to your actual domain names!
# The localhost defaults will cause the application to fail in production.
#
# Frontend application URL (React app) - used by backend for redirects and email links
FRONTEND_URL=http://localhost:3000

# Backend API server URL - used by backend internally
BACKEND_URL=http://localhost:5000
API_BASE_URL=http://localhost:5000

# React app environment variable (MUST be prefixed with REACT_APP_)
# This is used by the frontend to know where to make API calls
# ⚠️ THIS IS THE MOST IMPORTANT ONE FOR FRONTEND DEPLOYMENT
REACT_APP_API_URL=http://localhost:5000

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://176.123.10.237:3000
#ALLOWED_ORIGINS=http://176.123.10.237:3000,http://176.123.10.237:3000

# ==========================================
# Other Configuration
# ==========================================
MAX_REQUEST_SIZE=10mb

# ==========================================
# PRODUCTION EXAMPLE
# ==========================================
# Uncomment and modify these for production deployment:
# 
# DB_HOST=your-production-database-host.com
# DB_PORT=3306
# DB_USER=production_user
# DB_PASSWORD=strong-production-password
# DB_NAME=production_database
# 
# PORT=5000
# NODE_ENV=production
# 
# SESSION_SECRET=extremely-random-and-long-secret-key-for-production
# SESSION_TIMEOUT=3600000
# 
# BREVO_API_KEY=xkeysib-your-actual-brevo-api-key
# EMAIL_FROM=noreply@yourdomain.com
# BREVO_SENDER_EMAIL=noreply@yourdomain.com
# 
# FRONTEND_URL=https://yourapp.yourdomain.com
# BACKEND_URL=https://api.yourdomain.com
# API_BASE_URL=https://api.yourdomain.com
# REACT_APP_API_URL=https://api.yourdomain.com
# 
# CORS_ORIGIN=https://yourapp.yourdomain.com
# ALLOWED_ORIGINS=https://yourapp.yourdomain.com,https://www.yourapp.yourdomain.com
